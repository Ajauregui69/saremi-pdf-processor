# Configuración del microservicio PDF Processor

# Logging
LOG_LEVEL=INFO

# OCR Configuration
TESSERACT_LANG=spa+eng
USE_GPU=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Performance
MAX_WORKERS=4
TIMEOUT_SECONDS=120

# Allowed CORS Origins (separados por coma)
CORS_ORIGINS=http://localhost:3333,http://localhost:3000
