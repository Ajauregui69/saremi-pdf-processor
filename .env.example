# SarEmi API — Configuración

# Logging
LOG_LEVEL=INFO

# OCR Configuration
TESSERACT_LANG=spa+eng
USE_GPU=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Performance
MAX_WORKERS=4
TIMEOUT_SECONDS=120

# Allowed CORS Origins (separados por coma)
CORS_ORIGINS=http://localhost:3333,http://localhost:3000

# ── Autenticación multi-institución ──────────────────────────────────────────
# Formato: institution_id:api_key,institution_b:key2
# Generar keys seguras con: python -c "import secrets; print(secrets.token_hex(32))"
API_KEYS=demo_institution:changeme123

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Scrapers externos ─────────────────────────────────────────────────────────
SCRAPER_TIMEOUT_SECONDS=15

# Portal Lista Nominal INE
INE_PORTAL_URL=https://listanominal.ine.mx/app/DGICERG/listaNominal

# ── Detección de fraude con Claude Vision ─────────────────────────────────────
# Genera tu key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# Modelo para análisis visual (sonnet = mejor precisión, haiku = más rápido/barato)
FRAUD_DETECTION_MODEL=claude-sonnet-4-6
